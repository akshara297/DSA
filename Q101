if __name__ == "__main__":
    solver = AdvancedDPSolutions()
    
    print("--- 1. Super Egg Drop ---")
    print(f"Result (K=2, N=6): {solver.superEggDrop(2, 6)}")  # Expected: 3
    
    print("\n--- 2. Burst Balloons ---")
    print(f"Result ([3,1,5,8]): {solver.maxCoins([3,1,5,8])}")  # Expected: 167
    
    print("\n--- 3. Cherry Pickup II ---")
    grid = [[3,1,1],[2,5,1],[1,5,5],[2,1,1]]
    print(f"Result: {solver.cherryPickup(grid)}")  # Expected: 24
    
    print("\n--- 4. Minimum Cost to Cut a Stick ---")
    print(f"Result (n=7, cuts=[1,3,4,5]): {solver.minCost(7, [1,3,4,5])}")  # Expected: 16
