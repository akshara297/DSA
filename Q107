class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next

def reverseList(head):
    prev = None
    curr = head
    while curr:
        nxt = curr.next  # Save next node
        curr.next = prev # Reverse the link
        prev = curr      # Move prev forward
        curr = nxt       # Move curr forward
    return prev
