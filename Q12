def subarray_sum(nums, k):
    count = 0
    current_sum = 0
    prefix_sums = {0: 1}  # Base case: a prefix sum of 0 seen once
    
    for num in nums:
        current_sum += num
        if current_sum - k in prefix_sums:
            count += prefix_sums[current_sum - k]
        prefix_sums[current_sum] = prefix_sums.get(current_sum, 0) + 1
        
    return count
