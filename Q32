def remove_nth_from_end(head, n):
    dummy = ListNode(0, head)
    first = dummy
    second = dummy
    
    # Advance first pointer by n + 1 steps
    for _ in range(n + 1):
        first = first.next
        
    # Move both pointers together
    while first:
        first = first.next
        second = second.next
        
    # Delete the node
    second.next = second.next.next
    return dummy.next
