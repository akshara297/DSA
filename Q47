def my_sqrt(x):
    if x < 2:
        return x
    low, high = 1, x // 2
    res = 0
    while low <= high:
        mid = (low + high) // 2
        if mid * mid == x:
            return mid
        elif mid * mid < x:
            res = mid
            low = mid + 1
        else:
            high = mid - 1
    return res
