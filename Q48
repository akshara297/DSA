import math

def min_eating_speed(piles, h):
    low, high = 1, max(piles)
    res = high
    
    while low <= high:
        mid = (low + high) // 2
        # Calculate total hours spent at eating speed 'mid'
        hours_spent = sum(math.ceil(pile / mid) for pile in piles)
        
        if hours_spent <= h:
            res = mid
            high = mid - 1  # Try to find a smaller valid speed
        else:
            low = mid + 1   # Must speed up
            
    return res
