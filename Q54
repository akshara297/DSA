def diameter_of_binary_tree(root):
    max_diameter = 0
    
    def height(node):
        nonlocal max_diameter
        if not node: return 0
        left = height(node.left)
        right = height(node.right)
        max_diameter = max(max_diameter, left + right)
        return 1 + max(left, right)
        
    height(root)
    return max_diameter
