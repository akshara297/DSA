def max_path_sum(root):
    max_sum = float('-inf')
    
    def gain_from_node(node):
        nonlocal max_sum
        if not node: return 0
        
        # Drop negative paths by clamping to 0
        left_gain = max(gain_from_node(node.left), 0)
        right_gain = max(gain_from_node(node.right), 0)
        
        # Calculate sum if this node acts as the highest split node of the path
        current_path_sum = node.val + left_gain + right_gain
        max_sum = max(max_sum, current_path_sum)
        
        # Return maximum branch value this node can pass up to its parent
        return node.val + max(left_gain, right_gain)
        
    gain_from_node(root)
    return max_sum
