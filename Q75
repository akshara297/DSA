def num_islands(grid):
    if not grid:
        return 0
        
    rows, cols = len(grid), len(grid[0])
    island_count = 0
    
    def dfs(r, c):
        # Base cases for out-of-bounds or water/visited cells
        if r < 0 or r >= rows or c < 0 or c >= cols or grid[r][c] == "0":
            return
            
        # Sink the land cell to mark it visited
        grid[r][c] = "0"
        
        # Explore 4 directional neighbors
        dfs(r + 1, c)
        dfs(r - 1, c)
        dfs(r, c + 1)
        dfs(r, c - 1)

    for i in range(rows):
        for j in range(cols):
            if grid[i][j] == "1":
                island_count += 1
                dfs(i, j)  # Sink the entire island
                
    return island_count
