def num_decodings(s):
    if not s or s[0] == "0": return 0
    
    # Track states for the last two positions
    two_back, one_back = 1, 1
    
    for i in range(2, len(s) + 1):
        curr = 0
        # Single digit check
        if s[i-1] != "0":
            curr += one_back
        # Two digit check
        two_digit = int(s[i-2:i])
        if 10 <= two_digit <= 26:
            curr += two_back
            
        two_back = one_back
        one_back = curr
        
    return one_back
